// prisma/schema.prisma
// This file defines all our database tables and relationships

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User table — stores both regular users and admins
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String // hashed with bcrypt
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  // A user can have many orders and a cart
  orders    Order[]
  cartItems CartItem[]
}

// Product table — each jersey in the store
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  team        String
  price       Float
  imageUrl    String
  description String
  stock       Int      @default(100)
  createdAt   DateTime @default(now())

  // A product can appear in many cart items and order items
  cartItems  CartItem[]
  orderItems OrderItem[]
}

// CartItem — one row per product in a user's cart
model CartItem {
  id       Int @id @default(autoincrement())
  quantity Int @default(1)

  // Which user owns this cart item
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which product this cart item refers to
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Unique constraint: a user can only have one cart row per product
  @@unique([userId, productId])
}

// Order — placed when user checks out
model Order {
  id         Int         @id @default(autoincrement())
  totalPrice Float
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  // Which user placed this order
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // An order contains many items
  items OrderItem[]
}

// OrderItem — snapshot of what was ordered (product + quantity + price at time of order)
model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float // price at the time of order (products can change price later)

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

// Enum for order status
enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}
